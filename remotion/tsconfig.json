{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@design/*": ["./design/*"],
      "@compositions/*": ["./compositions/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
