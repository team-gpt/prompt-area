      "postcss": ">=8.5.10",
      "brace-expansion@1": "^1.1.12",
      "brace-expansion@2": "^2.0.2",
      "brace-expansion@>=4": "^5.0.5",
      "picomatch@<3": "^2.3.2",
      "picomatch@>=4": "^4.0.4"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "msw",
      "sharp",
      "unrs-resolver"
